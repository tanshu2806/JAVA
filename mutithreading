class ChatUser extends Thread {
    String userName;

    ChatUser(String name, int priority) {
        this.userName = name;
        this.setPriority(priority);
    }

    public void run() {
        System.out.println(userName + " [Priority:" + getPriority() + "] is sending a message...");
        for (int i = 1; i <= 3; i++) {
            System.out.println(userName + ": Message " + i);
            try {
                Thread.sleep(500);
            } catch (InterruptedException e) {
                System.out.println(userName + " was interrupted.");
            }
        }
        System.out.println(userName + " finished chatting.");
    }
}

public class ChatSystem {
    public static void main(String[] args) throws InterruptedException {
        ChatUser user1 = new ChatUser("Alice", Thread.MAX_PRIORITY);  // Priority 10
        ChatUser user2 = new ChatUser("Bob", Thread.NORM_PRIORITY);    // Priority 5
        ChatUser user3 = new ChatUser("Charlie", Thread.MIN_PRIORITY); // Priority 1

        user1.start();
        user2.start();
        user3.start();

        System.out.println("Is Alice alive? " + user1.isAlive());

        user1.join(); // wait for Alice to finish
        user2.join(); // wait for Bob to finish
        user3.join(); // wait for Charlie to finish

        System.out.println("Is Alice alive after join? " + user1.isAlive());
        System.out.println("All users done chatting.");
    }
}
